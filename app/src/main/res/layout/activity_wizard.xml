<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".WizardActivity">

    <TextView
        android:id="@+id/wizardEyebrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/builder_badge_background"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="@string/sentence_builder_eyebrow"
        android:textAllCaps="true"
        android:textColor="@color/builder_badge_text"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/wizardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/build_phrase_title"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
        android:textColor="@color/ink"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/select_a_word_from_the_dropdown"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
        android:textColor="@color/ink_muted" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sentencePreviewCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/warm_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/builder_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/sentencePreviewLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sentence_preview_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
                android:textColor="@color/ink_muted"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sentencePreviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:minHeight="60dp"
                android:text="@string/sentence_preview_placeholder"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                android:textColor="@color/ink"
                tools:text="Beach dog funny" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/selectedWordCountText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                    android:textColor="@color/ink_muted" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/speakSentenceButton"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speak_sentence_button"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/builder_action"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_btn_speak_now"
                    app:iconPadding="8dp"
                    app:iconTint="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/composerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/builder_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/composer_section_title"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/composer_section_helper"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                android:textColor="@color/ink_muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/wizard_scroll_instruction"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="@color/ink_muted" />

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/wizard_word_picker_container"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/selectedWordsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/selected_words_section_title"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        android:textColor="@color/ink"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/selectedWordsHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/selected_words_section_helper"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        android:textColor="@color/ink_muted" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/selected_word_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/done_button"
        android:textAllCaps="false"
        android:textColor="@color/ink"
        app:cornerRadius="18dp"
        app:strokeColor="@color/builder_card_stroke" />

</LinearLayout>